# ============================================
# AgendiX - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha com seus valores reais.
# NUNCA commite arquivos .env com credenciais reais.
# ============================================

# --------------------------------------------
# Supabase (obrigatório)
# --------------------------------------------
# Obtenha em: Project Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase service role (apenas para scripts Node.js, NUNCA no bundle)
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------
# Stripe (obrigatório para pagamentos)
# --------------------------------------------
# Publishable key (vá para o bundle, é pública)
VITE_STRIPE_PUBLISHABLE_KEY=

# Secret key (apenas Edge Functions, nunca no frontend)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --------------------------------------------
# OpenRouter (obrigatório para IA)
# --------------------------------------------
# ATENÇÃO: VITE_* vai para o bundle do navegador.
# Mover para Edge Function em futura sprint.
VITE_OPENROUTER_API_KEY=

# --------------------------------------------
# Gemini (obrigatório para IA)
# --------------------------------------------
# ATENÇÃO: VITE_* vai para o bundle do navegador.
# Mover para Edge Function em futura sprint.
VITE_GEMINI_API_KEY=

# --------------------------------------------
# Resend (apenas Edge Functions)
# --------------------------------------------
RESEND_API_KEY=

# --------------------------------------------
# Ambiente
# --------------------------------------------
NODE_ENV=development

# --------------------------------------------
# Supabase MCP (opencode)
# --------------------------------------------
# Personal Access Token do Supabase (Project Settings > Access Tokens)
SUPABASE_MCP_TOKEN=
# Project Ref (encontrado em Project Settings > General > Project ID)
SUPABASE_PROJECT_REF=
# Email da conta com modo dev (troca de tema). Vazio = ninguem tem dev.
VITE_DEV_EMAIL=

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$description": "Semantic tokens for Barber Dark mode — industrial modern aesthetic with gold accent on deep black.",
  "theme": "barber",
  "mode": "dark",
  "color": {
    "bg": "#121212",
    "card": "#1E1E1E",
    "cardElevated": "#2A2A2A",
    "cardHover": "rgba(255, 255, 255, 0.04)",
    "surface": "#252525",
    "divider": "rgba(255, 255, 255, 0.08)",
    "overlay": "rgba(0, 0, 0, 0.7)",
    "accent": "#C29B40",
    "accentHover": "#D4AF50",
    "accentDim": "rgba(194, 155, 64, 0.2)",
    "accentBorder": "rgba(194, 155, 64, 0.6)",
    "text": "#EAEAEA",
    "textSecondary": "#A0A0A0",
    "textMuted": "#525252",
    "border": "rgba(255, 255, 255, 0.05)",
    "borderStrong": "rgba(255, 255, 255, 0.1)",
    "inputBg": "rgba(0, 0, 0, 0.3)",
    "inputBorder": "rgba(255, 255, 255, 0.06)",
    "inputFocusBorder": "rgba(194, 155, 64, 0.6)",
    "danger": "#EF4444",
    "dangerBg": "rgba(239, 68, 68, 0.08)",
    "dangerBorder": "rgba(239, 68, 68, 0.3)",
    "success": "#10B981",
    "successBg": "rgba(16, 185, 129, 0.08)",
    "successBorder": "rgba(16, 185, 129, 0.2)",
    "warning": "#F59E0B",
    "warningBg": "rgba(245, 158, 11, 0.08)",
    "warningBorder": "rgba(245, 158, 11, 0.2)"
  },
  "gradient": {
    "card": "linear-gradient(135deg, #121212 0%, #1E1E1E 50%, #121212 100%)",
    "surface": "linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0) 100%)",
    "bgRadial": "radial-gradient(circle at 10% 90%, rgba(194, 155, 64, 0.12) 0%, transparent 40%), radial-gradient(circle at 90% 10%, rgba(194, 155, 64, 0.10) 0%, transparent 30%)"
  },
  "shadow": {
    "card": "0 12px 40px -12px rgba(0, 0, 0, 0.7), inset 0 0 0 1px rgba(255, 255, 255, 0.08)",
    "cardMobile": "0 4px 12px rgba(0, 0, 0, 0.5)",
    "cardAccent": "0 0 10px rgba(194, 155, 64, 0.4), 0 0 20px rgba(194, 155, 64, 0.2)",
    "cardGlow": "0 16px 36px -12px rgba(0,0,0,0.6), 0 8px 16px -8px rgba(0,0,0,0.4), inset 0 0 0 1px rgba(194, 155, 64, 0.1)",
    "buttonPrimary": "0 4px 20px rgba(194, 155, 64, 0.25)",
    "modal": "0 12px 40px -12px rgba(0, 0, 0, 0.7), inset 0 0 0 1px rgba(255, 255, 255, 0.08)"
  }
}
